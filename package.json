{
  "name": "fieldops-platform",
  "version": "0.1.0",
  "description": "HVAC field operations backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest --runInBand",
    "db:schema": "psql $DATABASE_URL -f src/db/schema.sql",
    "db:migrate": "psql $DATABASE_URL -f src/db/migrations/001_invite_codes.sql",
    "db:migrate2": "psql $DATABASE_URL -f src/db/migrations/002_visits_updated_at_deferred.sql",
    "db:seed:catalog": "node src/db/seed/catalog.js",
    "db:seed:roles": "node src/db/seed/roles.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "multer": "^2.2.0",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "supertest": "^7.0.0"
  }
}
